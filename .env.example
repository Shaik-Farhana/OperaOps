# OperaOps Environment Variables
# Copy this file to .env.local (preferred) or .env and fill in your values

# ─── Groq ─────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Hindsight (Vectorize) ────────────────────────────────
HINDSIGHT_API_KEY=your_hindsight_api_key_here
HINDSIGHT_BANK_ID=opera
HINDSIGHT_BASE_URL=https://api.hindsight.vectorize.io
# Legacy pipeline API (optional fallback if bank ID unset)
HINDSIGHT_PIPELINE_ID=

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Postgres (migrations) — use postgresql:// not https://
SUPABASE_DB_PASSWORD=
POSTGRES_HOST=db.PROJECT_REF.supabase.co
POSTGRES_USER=postgres
POSTGRES_DATABASE=postgres
SUPABASE_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# ─── cascadeflow budget config ────────────────────────────
CASCADE_BUDGET_USD=5.00
CASCADE_CHEAP_MODEL=openai/gpt-oss-20b
CASCADE_STRONG_MODEL=openai/gpt-oss-120b

# ─── MoE (DECA-IR) ────────────────────────────────────────
MOE_MEMORY_BYPASS_THRESHOLD=0.85
MOE_MAMBA_THRESHOLD=800
MOE_MAMBA_CHUNK_SIZE=400
MOE_VERIFY_ON_P1=false

# ─── LLM providers ────────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_api_key_here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_PROVIDER_PREFERENCE=groq
# Used by scripts/generate_incidents_nvidia.py (NeMo Data Designer)

# ─── Data flywheel ────────────────────────────────────────
FLYWHEEL_LOG_DIR=./data/trajectories

# ─── App config ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000
