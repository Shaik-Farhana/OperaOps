# OperaOps Environment Variables
# Copy this file to .env and fill in your values

# ─── Groq ─────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Hindsight (Vectorize) ────────────────────────────────
HINDSIGHT_API_KEY=your_hindsight_api_key_here
HINDSIGHT_PIPELINE_ID=your_hindsight_pipeline_id_here

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── cascadeflow budget config ────────────────────────────
CASCADE_BUDGET_USD=5.00
CASCADE_CHEAP_MODEL=qwen/qwen3-32b
CASCADE_STRONG_MODEL=openai/gpt-oss-120b

# ─── App config ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
