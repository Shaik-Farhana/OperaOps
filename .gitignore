*.pem
*.key
credentials.json
secrets/

# Python / local artifacts
__pycache__/
*.py[cod]
.pytest_cache/
backend/data/

# Generated data artifacts (keep incidents.json tracked)
data/generated/
data/.hindsight_migration_v1.json
